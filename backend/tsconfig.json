{
  "compilerOptions": {
    "target": "ES2022",                                  /* Versão moderna do JavaScript */
    "module": "nodenext",                                /* Padrão do Node.js */
    "moduleResolution": "nodenext",
    "rootDir": "./src",                                  /* Onde estão os nossos arquivos .ts */
    "outDir": "./dist",                                  /* Para onde vai o código compilado */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,                                      /* Mantém o TypeScript rigoroso e seguro */
    "skipLibCheck": true
  },
  "include": ["src/**/*"],                               /* Diz ao TS para olhar apenas dentro da pasta src */
  "exclude": ["node_modules"]
}